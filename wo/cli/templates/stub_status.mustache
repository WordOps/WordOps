# Stub status NGINX CONFIGURATION
# DO NOT MODIFY, ALL CHANGES WILL BE LOST AFTER AN WordOps (wo) UPDATE
{{#phpconf}}
upstream phpstatus {
    server unix:/run/php/php81-fpm.sock;
}
upstream php82opcache {
    server unix:/run/php/php82-fpm.sock;
}
upstream php83opcache {
    server unix:/run/php/php83-fpm.sock;
}
upstream php84opcache {
    server unix:/run/php/php84-fpm.sock;
}
upstream php85opcache {
    server unix:/run/php/php85-fpm.sock;
}
{{/phpconf}}
server {
    listen 127.0.0.1:80;
    server_name 127.0.0.1 localhost;
    access_log off;
    log_not_found off;
    root /var/www/22222/htdocs;
    allow 127.0.0.1;
    deny all;
    location ~ /(stub_status|nginx_status) {
        stub_status on;
        allow 127.0.0.1;
        deny all;
        access_log off;
        log_not_found off;
    }
    {{#phpconf}}
    location ~ /(status|ping) {
        include fastcgi_params;
        fastcgi_pass phpstatus;
        access_log off;
        log_not_found off;
    }
    location / {
        try_files $uri $uri/ /index.php$is_args$args;
    }
    location /cache/opcache/php81.php {
        try_files $uri =404;
        include fastcgi_params;
        fastcgi_pass phpstatus;
        access_log off;
        log_not_found off;
    }
    location /cache/opcache/php82.php {
        try_files $uri =404;
        include fastcgi_params;
        fastcgi_pass php82opcache;
        access_log off;
        log_not_found off;
    }
    location /cache/opcache/php83.php {
        try_files $uri =404;
        include fastcgi_params;
        fastcgi_pass php83opcache;
        access_log off;
        log_not_found off;
    }
    location /cache/opcache/php84.php {
        try_files $uri =404;
        include fastcgi_params;
        fastcgi_pass php84opcache;
        access_log off;
        log_not_found off;
    }
    location /cache/opcache/php85.php {
        try_files $uri =404;
        include fastcgi_params;
        fastcgi_pass php85opcache;
        access_log off;
        log_not_found off;
    }
    {{/phpconf}}
}
